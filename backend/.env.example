# ─────────────────────────────────────────────────────────────
# HeatWatch Backend — Environment Variables
# Open-Meteo needs NO API key — just run as-is!
# ─────────────────────────────────────────────────────────────

PORT=5000

# No weather API key needed — Open-Meteo is 100% free with no signup
# https://open-meteo.com

# Firebase (for saving citizen reports — optional)
# Set USE_MOCK_DB=true to skip Firebase entirely (recommended for demo)
USE_MOCK_DB=true

# Default city when no location is provided
DEFAULT_CITY=New Delhi
DEFAULT_LAT=28.6139
DEFAULT_LON=77.2090
